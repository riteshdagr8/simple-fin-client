# Server
PORT=4200

# JWT secret — REQUIRED. Use a long random string (e.g., 48+ random bytes hex).
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Encryption key for at-rest secrets (LLM API keys, SimpleFIN access URLs).
# REQUIRED. Use exactly 64 hex chars (32 bytes) or any string (will be SHA-256 hashed).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Environment: development or production
NODE_ENV=development

# CORS allowlist (comma-separated). Default: localhost on common ports.
CORS_ORIGIN=http://localhost:4200,http://localhost:6173

# Email (Gmail: use an App Password https://support.google.com/accounts/answer/185833)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=FinApp <your-email@gmail.com>

# App URL (used in email links)
APP_URL=http://localhost:4200

# Daily sync schedule (default: 3:07 AM)
# SYNC_CRON=7 3 * * *
