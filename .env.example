# Copy this file to .env and fill in your values

# Server
PORT=3000

# JWT secret (change this to a long random string in production)
JWT_SECRET=finapp-dev-secret-change-in-production

# Email (Gmail: use an App Password https://support.google.com/accounts/answer/185833)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=FinApp <your-email@gmail.com>

# App URL (used in email links)
APP_URL=http://localhost:3000

# Daily sync schedule (default: 3:07 AM)
# SYNC_CRON=7 3 * * *
