# Copy this file to .env and fill in your values

# Server
PORT=4200

# JWT secret — REQUIRED. Use a long random string (e.g., 48+ random bytes hex).
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# The app will refuse to start if this matches the well-known default value.
JWT_SECRET=

# Encryption key for at-rest secrets (LLM API keys, SimpleFIN access URLs).
# REQUIRED. Use exactly 64 hex chars (32 bytes) or any string (will be SHA-256 hashed).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Changing this key will invalidate all stored encrypted secrets.
ENCRYPTION_KEY=

# CORS allowlist (comma-separated). Default: localhost on common ports.
CORS_ORIGIN=http://localhost:4200,http://localhost:6173,http://localhost:6174,http://localhost:6175,http://localhost:6176

# Email (Resend: https://resend.com)
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM=FinApp <noreply@yourdomain.com>

# App URL (used in email links)
APP_URL=http://localhost:4200

# Daily sync schedule (default: 3:07 AM)
# SYNC_CRON=7 3 * * *
